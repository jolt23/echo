# Copy this file to .env and edit (Docker Compose loads .env automatically):
#   cp .env.example .env
#
# You do not need to change docker-compose.yml — variables below override defaults.

# Capture → real backend (required for pass-through recording)
BACKEND_BASE_URL=https://<backend-domain>/<backend-path>

# Dev only: set true to skip TLS certificate verification for the backend (insecure)
CAPTURE_INSECURE_SSL=false

# Optional: host ports mapped into containers
CAPTURE_PORT=9090
EMITTER_PORT=9091
WIREMOCK_EXPOSE_PORT=8090